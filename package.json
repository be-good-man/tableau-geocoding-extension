{
  "name": "tableau-geocoding-extension",
  "version": "1.0.0",
  "description": "Tableau dashboard extension that geocodes addresses and writes results to a spatial parameter.",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "concurrently --kill-others \"webpack --mode development --watch\" \"npm:start\"",
    "start": "http-server ./dist -p 8765 -c-1",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test-watch": "jest --watch",
    "test-coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourorg/tableau-geocoding-extension.git"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "http-server": "^14.1.0"
  },
  "devDependencies": {
    "@tableau/extensions-api-types": "^1.17.0",
    "@types/jest": "^29.5.0",
    "concurrently": "^8.2.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^6.8.0",
    "eslint": "^8.50.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.7.0",
    "style-loader": "^3.3.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
